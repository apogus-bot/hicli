  esac
}

cmd_companies() {
  local sub="${1:-me}"
  shift || true
  case "$sub" in
    me)
      api_get "/companies/me" | pretty
      ;;
    create)
      local body
      body=$(parse_json_flags "$@")
      ensure_json "$body"
      api_post "/companies/create" "$body" | pretty
      ;;
    search)
      [[ -n "${1:-}" ]] || err "Usage: hi companies search <QUERY>"
      api_get "/companies/search?q=$(urlencode "$1")" | pretty
      ;;
    invite)
      local body
      body=$(parse_json_flags "$@")
      ensure_json "$body"
      api_post "/companies/invites" "$body" | pretty
      ;;
    requests)
      local body
      body=$(parse_json_flags "$@")
      ensure_json "$body"
      api_post "/companies/requests" "$body" | pretty
      ;;
    *) err "Unknown: hi companies $sub" ;;
  esac
}

cmd_team() {
  local sub="${1:-list}"
  shift || true
  case "$sub" in
    list)
      local q='' status='all'
      while [[ $# -gt 0 ]]; do
        case "$1" in
          --q) q="$2"; shift 2 ;;
          --status) status="$2"; shift 2 ;;
          *) err "Unknown arg for hi team list: $1" ;;
        esac
      done
      api_get "/team-listings?q=$(urlencode "$q")&status=$(urlencode "$status")" | pretty
      ;;
    *) err "Unknown: hi team $sub" ;;
  esac
}

cmd_onboarding() {
  local body
  body=$(parse_json_flags "$@")
  ensure_json "$body"
  api_post "/onboarding/complete" "$body" | pretty
}

cmd_help() {
  cat <<'EOF'
HomeInsight CLI

USAGE: hi-homeinsight <command> [args]

CORE:
  login [--email E]                                Authenticate (password comes from HI_PASSWORD or local auth env)
  auth status | ensure                             Inspect or refresh auth
  whoami                                           Current session info
  profile get | update | avatar-upload | load-area get | load-area set | load-area run

DASHBOARD:
  dashboard summary | activity
  notifications list | read <ID> | read-all

LISTINGS:
  properties list [--limit N] [--status S]
  properties get <ID>
  properties create                                Quick-create from JSON stdin / --json / --file
  properties update <ID>                           PATCH from JSON stdin / --json / --file
  properties prefill                               Generate prefill payload from JSON
  properties generate-content                      Generate listing copy from JSON
  properties publish | unpublish | release | restore | mark-sold <ID>
  properties delete <ID>
  properties analytics | timeline | analysis | chat | cover-page | cover-page-notes <ID>

PHOTOS:
  photos stage | edit | save | manage

DOCUMENTS:
  documents list [--property ID]
  documents upload --property ID --file PATH [--type TYPE] [--title T] [--description D] [--public]
  documents reorder <PROPERTY_ID>
  documents analytics <PROPERTY_ID>
  documents download-all <PROPERTY_ID>
  documents share <PROPERTY_ID> <DOC_ID>
  documents share-open <PROPERTY_ID>
  documents share-multiple <PROPERTY_ID>
  documents request-access <PROPERTY_ID>
  documents access-requests <PROPERTY_ID>
  documents grant-access <PROPERTY_ID>
  documents revoke-access <PROPERTY_ID>
  documents shared-with-me

PACKAGES:
  packages list | get <ID> | create | update <ID>
  packages co-agent add | get | revoke | accept | decline <ID>
  packages share <PROPERTY_ID>
  packages analytics <PROPERTY_ID>

OFFERS:
  offers list <PROPERTY_ID>
  offers get <PROPERTY_ID> <OFFER_ID>
  offers submit <PROPERTY_ID>
  offers respond <PROPERTY_ID> <OFFER_ID>
  offers accept | reject | counter | withdraw <OFFER_ID>
  offers schedule <PROPERTY_ID> <OFFER_ID>
  offers share <PROPERTY_ID>
  offers docs list | upload

ANALYSIS:
  analysis start | get | pending | stream | issues

AGENT / TEAM:
  leads list | create
  companies me | create | search | invite | requests
  team list
  onboarding                                        Complete onboarding flow from JSON

NOTES:
  - JSON body commands accept: --json '<payload>', --file payload.json, or stdin
  - Listing prep flow: create a property (or create a package that returns property_id), then upload photos/documents to that property while it stays in draft
  - Buyer review packages can auto-create a shell draft property; use the returned property_id for document upload and optional photo save workflows
  - Secrets stay local in ~/.config/hi-cli-homeinsight/
  - This public CLI intentionally excludes admin, cron, sync, webhook, and blog surfaces
EOF
}

case "${1:-help}" in
  login) shift; cmd_login "$@" ;;
  auth) shift; cmd_auth "$@" ;;
  whoami) cmd_whoami ;;
  profile) shift; cmd_profile "$@" ;;
  dashboard) shift; cmd_dashboard "$@" ;;
  notifications) shift; cmd_notifications "$@" ;;
  properties) shift; cmd_properties "$@" ;;
  photos) shift; cmd_photos "$@" ;;
  documents|docs) shift; cmd_documents "$@" ;;
  packages) shift; cmd_packages "$@" ;;
  offers) shift; cmd_offers "$@" ;;
  analysis) shift; cmd_analysis "$@" ;;
  leads) shift; cmd_leads "$@" ;;
  companies) shift; cmd_companies "$@" ;;
  team) shift; cmd_team "$@" ;;
  onboarding) shift; cmd_onboarding "$@" ;;
  help|--help|-h) cmd_help ;;
  *) err "Unknown: $1 — run 'hi-homeinsight help'" ;;
esac
